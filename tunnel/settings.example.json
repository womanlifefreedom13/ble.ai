{
  "livekit_url": "wss://meet.bale.ai",
  "room_name": "REPLACE_WITH_BALE_MEETING_ID",

  "token_mode": "preset",
  "entry_token": "PASTE_BALE_JWT_FOR_ENTRY_HERE",
  "exit_token":  "PASTE_BALE_JWT_FOR_EXIT_HERE",

  "socks_host": "127.0.0.1",
  "socks_port": 1080,

  "log_level": "INFO",

  "_selfhost_example": {
    "token_mode": "selfhost",
    "livekit_url": "wss://livekit.your-exit-domain.tld",
    "api_key": "APIxxxxxxxx",
    "api_secret": "secretxxxxxxxx",
    "token_ttl_hours": 168
  },

  "_token_reference_syntax": [
    "Token values support these forms:",
    "  raw JWT string",
    "  '@/etc/tunnel/entry.token'   - read from a file (rotate without restart)",
    "  '${TUNNEL_ENTRY_TOKEN}'       - read from an env var"
  ]
}
